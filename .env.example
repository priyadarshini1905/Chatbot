# ============================================
# Madurai Smart Assistant — Environment Config
# ============================================

# Groq API Key (REQUIRED)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Server Port
PORT=3000

# ============================================
# OPTIONAL — Future Integration API Keys
# Uncomment and add keys when ready to enable
# ============================================

# Google Maps (Directions, Nearby Search, Distance)
# Get key: https://console.cloud.google.com/apis
# GOOGLE_MAPS_API_KEY=your_key_here

# Live Traffic (Google Maps Traffic / TomTom / HERE)
# TRAFFIC_API_KEY=your_key_here
# TRAFFIC_API_URL=https://api.example.com/traffic

# Weather API (OpenWeatherMap free tier: 1000 calls/day)
# Get key: https://openweathermap.org/api
# WEATHER_API_KEY=your_key_here
# WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Temple Queue Booking API
# TEMPLE_BOOKING_API_KEY=your_key_here
# TEMPLE_BOOKING_API_URL=https://api.example.com/temple

# Event Notifications (Push / Email / WhatsApp)
# NOTIFICATION_SERVICE_URL=https://api.example.com/notify
# TWILIO_ACCOUNT_SID=your_sid_here
# TWILIO_AUTH_TOKEN=your_token_here

# AI Crowd Prediction ML Model
# CROWD_ML_MODEL_URL=https://api.example.com/crowd-model

# Recommendations Database
# RECOMMENDATIONS_DB_URL=mongodb://localhost:27017/madurai-assistant
